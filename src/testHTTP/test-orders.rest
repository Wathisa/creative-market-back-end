### 1. Login (User)
# @name login
POST http://localhost:7777/api/auth/login
Content-Type: application/json

{
  "email": "usertest1@example.com",
  "password": "password1234"
}

### 2. สร้างคำสั่งซื้อ (Success - เลือกที่อยู่จากโปรไฟล์)
# @name checkoutSuccess
POST http://localhost:7777/api/orders/checkout
Content-Type: application/json

{
  "paymentMethod": "promptpay"
}

### 2.1 สร้างคำสั่งซื้อ (Success - กรอกที่อยู่ใหม่ Manual)
POST http://localhost:7777/api/orders/checkout
Content-Type: application/json

{
  "paymentMethod": "credit_card",
  "shippingAddress": {
    "recipientName": "สมชาย ใจดี",
    "phone": "0812345678",
    "street": "123/45 หมู่บ้านทดสอบ",
    "district": "บางรัก",
    "province": "กรุงเทพ",
    "postcode": "10500"
  }
}

### 2.2 สร้างคำสั่งซื้อ (Fail - ไม่ส่ง paymentMethod)
POST http://localhost:7777/api/orders/checkout
Content-Type: application/json

{
  "shippingAddress": {
    "recipientName": "สมชาย ใจดี"
  }
}


### 3. ดึงประวัติการสั่งซื้อทั้งหมด (ของตัวเองเท่านั้น)
GET http://localhost:7777/api/orders/

### 4. ดูรายละเอียดคำสั่งซื้อรายอัน (พร้อมเช็ค Ownership)
# ลองเปลี่ยน ID เป็นของคนอื่นเพื่อทดสอบความปลอดภัย (ควรได้ 404)
GET http://localhost:7777/api/orders/ไอดีของออเดอร์

### 5. อัปเดตสถานะเป็นจ่ายเงินแล้ว (Mock PromptPay Success)
PATCH http://localhost:7777/api/orders/status/ไอดีของออเดอร์
Content-Type: application/json

{
  "status": "paid"
}

### 6. ยกเลิกออเดอร์ (เพื่อทดสอบการคืนสต็อก)
PATCH http://localhost:7777/api/orders/status/ไอดีของออเดอร์
Content-Type: application/json

{
  "status": "cancelled"
}

### 7. สำหรับ Admin เท่านั้น: ดูรายการสั่งซื้อทั้งหมดในระบบ
GET http://localhost:7777/api/orders/all
